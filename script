// Espera o carregamento completo da página
window.addEventListener('load', () => {
  console.log("Site AgroForte carregado com sucesso!");

  // Seleciona todos os links do menu que possuem âncoras
  const navLinks = document.querySelectorAll('nav a');

  // Adiciona evento de clique para rolar suavemente
  navLinks.forEach(link => {
    link.addEventListener('click', function(e) {
      e.preventDefault();
      const targetId = this.getAttribute('href').substring(1);
      const targetSection = document.getElementById(targetId);
      
      // Rola suavemente até a seção alvo
      targetSection.scrollIntoView({ behavior: 'smooth' });
    });
  });

  // Cria um botão para voltar ao topo
  const backToTopBtn = document.createElement('button');
  backToTopBtn.textContent = 'Topo';
  backToTopBtn.id = 'backToTop';
  document.body.appendChild(backToTopBtn);

  // Estiliza o botão com CSS via JavaScript
  const btnStyle = backToTopBtn.style;
  btnStyle.position = 'fixed';
  btnStyle.bottom = '20px';
  btnStyle.right = '20px';
  btnStyle.padding = '10px 15px';
  btnStyle.backgroundColor = '#2e7d32';
  btnStyle.color = '#fff';
  btnStyle.border = 'none';
  btnStyle.borderRadius = '5px';
  btnStyle.cursor = 'pointer';
  btnStyle.display = 'none'; // Escondido inicialmente
  btnStyle.zIndex = '1000';

  // Mostra o botão após rolar 300px
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopBtn.style.display = 'block';
    } else {
      backToTopBtn.style.display = 'none';
    }
  });

  // Evento de clique no botão para voltar ao topo
  backToTopBtn.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
});
